# Copie ce fichier en ".env" et renseigne tes clés.

# Mistral (Devstral, Codestral…) — https://console.mistral.ai/
MISTRAL_API_KEY=ta_cle_ici

# Groq (Llama 3.3 70B, gratuit, function calling) — https://console.groq.com/keys
# Laisse vide si tu n'utilises pas Groq : les modèles n'apparaîtront pas.
GROQ_API_KEY=

# Ollama (modèles locaux) — optionnel, adresse par défaut ci-dessous.
# OLLAMA_URL=http://localhost:11434
