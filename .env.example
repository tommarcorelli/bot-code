# Copie ce fichier en ".env" et renseigne tes clés.

# Mistral (Devstral, Codestral…) — https://console.mistral.ai/
MISTRAL_API_KEY=ta_cle_ici

# Groq (Llama 3.3 70B, gratuit, function calling) — https://console.groq.com/keys
# Laisse vide si tu n'utilises pas Groq : les modèles n'apparaîtront pas.
GROQ_API_KEY=

# Gemini (Google, gratuit, function calling) — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Ollama (modèles locaux) — optionnel, adresse par défaut ci-dessous.
# OLLAMA_URL=http://localhost:11434

# --- Réseau / démarrage (optionnel) ---
# Hôte d'écoute : 127.0.0.1 = ce PC seulement (défaut) ; 0.0.0.0 = réseau local
# (nécessaire pour l'accès téléphone ; utilise plutôt le raccourci « Wi-Fi »).
# HOST=127.0.0.1
# PORT=5000
# DEBUG=1   # active le débogueur Werkzeug — DÉV UNIQUEMENT (exécution de code à distance)
